{
  "name": "craig-bryson-pub-quiz",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:full": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "setup": "npm run db:up && npm run db:wait && npm run db:migrate && npm run db:seed && npm run automation:validate && npm run automation:schedule",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:wait": "tsx server/scripts/waitForDb.ts",
    "db:migrate": "tsx server/scripts/migrate.ts",
    "db:seed": "tsx server/scripts/seed.ts",
    "automation:generate": "tsx server/scripts/generate.ts",
    "automation:validate": "tsx server/scripts/validate.ts",
    "automation:schedule": "tsx server/scripts/schedule.ts",
    "automation:publish": "tsx server/scripts/publish.ts",
    "automation:refresh": "tsx server/scripts/refreshSources.ts",
    "automation:daily": "npm run automation:generate && npm run automation:validate && npm run automation:schedule && npm run automation:publish && npm run automation:refresh",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "fastify": "^5.7.4",
    "pg": "^8.19.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
